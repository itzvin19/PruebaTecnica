    <!-- Mobile Header -->
    <nav class="navbar mobile-header sticky-top">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
                <span class="navbar-toggler-icon"></span>
            </button>
            <span class="navbar-brand mb-0 h1">
                <i class="bi bi-bar-chart-fill"></i> Analytics
            </span>
            <div></div>
        </div>
    </nav>

    <!-- Offcanvas Sidebar for Mobile -->
    <div class="offcanvas offcanvas-start text-white" tabindex="-1" id="sidebarOffcanvas">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title d-flex align-items-center">
                <i class="bi bi-bar-chart-fill fs-3 me-2"></i>
                Analytics
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <nav class="nav flex-column">
                <a class="nav-link active text-white" href="#"><i class="bi bi-house-door me-2"></i>Dashboard</a>
                <a class="nav-link text-white-50" href="#"><i class="bi bi-graph-up me-2"></i>Reportes</a>
                <a class="nav-link text-white-50" href="#"><i class="bi bi-people me-2"></i>Usuarios</a>
                <a class="nav-link text-white-50" href="#"><i class="bi bi-cart me-2"></i>Ventas</a>
                <a class="nav-link text-white-50" href="#"><i class="bi bi-gear me-2"></i>Configuración</a>
            </nav>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar p-3">
                <div class="d-flex align-items-center mb-4">
                    <i class="bi bi-bar-chart-fill fs-3 me-2"></i>
                    <h4 class="mb-0">Analytics</h4>
                </div>
                <nav class="nav flex-column">
                    <a class="nav-link active" href="#"><i class="bi bi-house-door me-2"></i>Dashboard</a>
                    <a class="nav-link" href="#"><i class="bi bi-graph-up me-2"></i>Reportes</a>
                    <a class="nav-link" href="#"><i class="bi bi-people me-2"></i>Usuarios</a>
                    <a class="nav-link" href="#"><i class="bi bi-cart me-2"></i>Ventas</a>
                    <a class="nav-link" href="#"><i class="bi bi-gear me-2"></i>Configuración</a>
                </nav>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 p-4">
                <!-- Header -->
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
                    <div>
                        <span id="user-greetings">@ViewBag.Greetings</span>
                        <h2>Dashboard Principal</h2>
                        <p class="text-muted mb-0">Resumen de métricas y estadísticas</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary"><i class="bi bi-download"></i> <span class="d-none d-sm-inline">Exportar</span></button>
                        <button class="btn btn-primary"><i class="bi bi-funnel"></i> <span class="d-none d-sm-inline">Filtros</span></button>
                    </div>
                </div>

                <!-- KPI Cards -->
                <div class="row mb-4">
                    <div class="col-sm-6 col-lg-3 mb-3">
                        <div class="card kpi-card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <p class="mb-1 opacity-75">Ingresos Totales</p>
                                        <h3 class="mb-0">$124,580</h3>
                                        <small><i class="bi bi-arrow-up"></i> +12.5% vs mes anterior</small>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-currency-dollar"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3 mb-3">
                        <div class="card kpi-card success">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <p class="mb-1 opacity-75">Nuevos Clientes</p>
                                        <h3 class="mb-0">1,245</h3>
                                        <small><i class="bi bi-arrow-up"></i> +8.2% esta semana</small>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-person-plus"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3 mb-3">
                        <div class="card kpi-card warning">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <p class="mb-1 opacity-75">Órdenes Pendientes</p>
                                        <h3 class="mb-0">89</h3>
                                        <small><i class="bi bi-arrow-down"></i> -3.4% hoy</small>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-clock-history"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3 mb-3">
                        <div class="card kpi-card info">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <p class="mb-1 opacity-75">Tasa Conversión</p>
                                        <h3 class="mb-0">3.42%</h3>
                                        <small><i class="bi bi-arrow-up"></i> +0.5% esta semana</small>
                                    </div>
                                    <div class="stat-icon">
                                        <i class="bi bi-graph-up-arrow"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Row 1 -->
                <div class="row mb-4">
                    <div class="col-lg-8 mb-3">
                        <div class="card">
                            <div class="card-header bg-white">
                                <h5 class="mb-0">Ventas Mensuales</h5>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="salesChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-3">
                        <div class="card">
                            <div class="card-header bg-white">
                                <h5 class="mb-0">Distribución por Categoría</h5>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="categoryChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Row 2 -->
                <div class="row">
                    <div class="col-lg-6 mb-3">
                        <div class="card">
                            <div class="card-header bg-white">
                                <h5 class="mb-0">Tráfico por Fuente</h5>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="trafficChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 mb-3">
                        <div class="card">
                            <div class="card-header bg-white">
                                <h5 class="mb-0">Productos Más Vendidos</h5>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="productsChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script src="/js/charts.js"></script>